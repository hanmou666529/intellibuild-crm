<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.crm.mapper.CrmPipelineMapper">

    <resultMap type="CrmPipeline" id="CrmPipelineResult">
        <id     property="pipelineId"       column="pipeline_id"        />
        <result property="customerId"       column="customer_id"        />
        <result property="orderId"          column="order_id"           />
        <result property="stage"            column="stage"              />
        <result property="amount"           column="amount"             />
        <result property="probability"      column="probability"        />
        <result property="expectedCloseDate" column="expected_close_date" />
        <result property="delFlag"          column="del_flag"           />
        <result property="createBy"         column="create_by"          />
        <result property="createTime"       column="create_time"        />
        <result property="updateBy"         column="update_by"          />
        <result property="updateTime"       column="update_time"        />
        <result property="remark"           column="remark"             />
        <result property="customerName"     column="customer_name"      />
        <result property="orderNo"          column="order_no"           />
    </resultMap>

    <sql id="selectCrmPipelineVo">
        select p.pipeline_id, p.customer_id, p.order_id, p.stage, p.amount,
               p.probability, p.expected_close_date,
               p.del_flag, p.create_by, p.create_time, p.update_by, p.update_time, p.remark,
               c.customer_name, o.order_no
        from crm_pipeline p
        left join crm_customer c on p.customer_id = c.customer_id
        left join crm_order o on p.order_id = o.order_id
    </sql>

    <select id="selectCrmPipelineList" parameterType="CrmPipeline" resultMap="CrmPipelineResult">
        <include refid="selectCrmPipelineVo"/>
        where p.del_flag = '0'
        <if test="customerId != null">
            AND p.customer_id = #{customerId}
        </if>
        <if test="orderId != null">
            AND p.order_id = #{orderId}
        </if>
        <if test="stage != null and stage != ''">
            AND p.stage = #{stage}
        </if>
        <if test="params.dataScope != null and params.dataScope != ''">
            ${params.dataScope}
        </if>
    </select>

    <select id="selectCrmPipelineById" parameterType="Long" resultMap="CrmPipelineResult">
        <include refid="selectCrmPipelineVo"/>
        where p.pipeline_id = #{pipelineId}
    </select>

    <select id="selectPipelineByCustomerId" parameterType="Long" resultMap="CrmPipelineResult">
        <include refid="selectCrmPipelineVo"/>
        where p.del_flag = '0' and p.customer_id = #{customerId}
    </select>

    <insert id="insertCrmPipeline" parameterType="CrmPipeline" useGeneratedKeys="true" keyProperty="pipelineId">
        insert into crm_pipeline
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="pipelineId != null">pipeline_id,</if>
            <if test="customerId != null">customer_id,</if>
            <if test="orderId != null">order_id,</if>
            <if test="stage != null and stage != ''">stage,</if>
            <if test="amount != null">amount,</if>
            <if test="probability != null">probability,</if>
            <if test="expectedCloseDate != null">expected_close_date,</if>
            <if test="createBy != null and createBy != ''">create_by,</if>
            <if test="remark != null and remark != ''">remark,</if>
            create_time
        </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="pipelineId != null">#{pipelineId},</if>
            <if test="customerId != null">#{customerId},</if>
            <if test="orderId != null">#{orderId},</if>
            <if test="stage != null and stage != ''">#{stage},</if>
            <if test="amount != null">#{amount},</if>
            <if test="probability != null">#{probability},</if>
            <if test="expectedCloseDate != null">#{expectedCloseDate},</if>
            <if test="createBy != null and createBy != ''">#{createBy},</if>
            <if test="remark != null and remark != ''">#{remark},</if>
            sysdate()
        </trim>
    </insert>

    <update id="updateCrmPipeline" parameterType="CrmPipeline">
        update crm_pipeline
        <set>
            <if test="customerId != null">customer_id = #{customerId},</if>
            <if test="orderId != null">order_id = #{orderId},</if>
            <if test="stage != null">stage = #{stage},</if>
            <if test="amount != null">amount = #{amount},</if>
            <if test="probability != null">probability = #{probability},</if>
            <if test="expectedCloseDate != null">expected_close_date = #{expectedCloseDate},</if>
            <if test="updateBy != null and updateBy != ''">update_by = #{updateBy},</if>
            <if test="remark != null">remark = #{remark},</if>
            update_time = sysdate()
        </set>
        where pipeline_id = #{pipelineId}
    </update>

    <update id="updateStage" parameterType="CrmPipeline">
        update crm_pipeline
        <set>
            <if test="stage != null and stage != ''">stage = #{stage},</if>
            <if test="updateBy != null and updateBy != ''">update_by = #{updateBy},</if>
            update_time = sysdate()
        </set>
        where pipeline_id = #{pipelineId}
    </update>

    <update id="deleteCrmPipelineByIds" parameterType="String">
        update crm_pipeline set del_flag = '2' where pipeline_id in
        <foreach collection="array" item="pipelineId" open="(" separator="," close=")">
            #{pipelineId}
        </foreach>
    </update>

    <select id="countGroupByStage" resultType="java.util.Map">
        select stage as name, count(1) as value
        from crm_pipeline where del_flag = '0' and stage is not null and stage != ''
        group by stage
    </select>

    <update id="updateCustomerId">
        update crm_pipeline set customer_id = #{newId}, update_time = sysdate()
        where customer_id = #{oldId}
    </update>

</mapper>
