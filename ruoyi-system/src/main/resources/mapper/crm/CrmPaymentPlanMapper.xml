<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.crm.mapper.CrmPaymentPlanMapper">

    <resultMap type="CrmPaymentPlan" id="CrmPaymentPlanResult">
        <id     property="planId"          column="plan_id"            />
        <result property="orderId"         column="order_id"           />
        <result property="contractId"      column="contract_id"        />
        <result property="planAmount"      column="plan_amount"        />
        <result property="actualAmount"    column="actual_amount"      />
        <result property="planDate"        column="plan_date"          />
        <result property="actualDate"      column="actual_date"        />
        <result property="status"          column="status"             />
        <result property="paymentMethod"   column="payment_method"     />
        <result property="delFlag"         column="del_flag"           />
        <result property="createBy"        column="create_by"          />
        <result property="createTime"      column="create_time"        />
        <result property="updateBy"        column="update_by"          />
        <result property="updateTime"      column="update_time"        />
        <result property="remark"          column="remark"             />
        <result property="orderNo"         column="order_no"           />
        <result property="customerName"    column="customer_name"      />
        <result property="belongUserId"    column="belong_user_id"     />
        <result property="belongDeptId"    column="belong_dept_id"     />
    </resultMap>

    <sql id="selectCrmPaymentPlanVo">
        select pp.plan_id, pp.order_id, pp.contract_id, pp.plan_amount, pp.actual_amount,
               pp.plan_date, pp.actual_date, pp.status, pp.payment_method,
               pp.del_flag, pp.create_by, pp.create_time, pp.update_by, pp.update_time, pp.remark,
               pp.belong_user_id, pp.belong_dept_id,
               o.order_no, c.customer_name
        from crm_payment_plan pp
        left join crm_order o on pp.order_id = o.order_id
        left join crm_customer c on o.customer_id = c.customer_id
    </sql>

    <select id="selectCrmPaymentPlanList" parameterType="CrmPaymentPlan" resultMap="CrmPaymentPlanResult">
        <include refid="selectCrmPaymentPlanVo"/>
        where pp.del_flag = '0'
        <if test="orderId != null">
            AND pp.order_id = #{orderId}
        </if>
        <if test="contractId != null">
            AND pp.contract_id = #{contractId}
        </if>
        <if test="status != null and status != ''">
            AND pp.status = #{status}
        </if>
        <if test="params.beginTime != null and params.beginTime != ''">
            AND date_format(pp.plan_date,'%Y%m%d') &gt;= date_format(#{params.beginTime},'%Y%m%d')
        </if>
        <if test="params.endTime != null and params.endTime != ''">
            AND date_format(pp.plan_date,'%Y%m%d') &lt;= date_format(#{params.endTime},'%Y%m%d')
        </if>
        <if test="orderNo != null and orderNo != ''">
            AND o.order_no LIKE CONCAT('%', #{orderNo}, '%')
        </if>
        <if test="customerName != null and customerName != ''">
            AND c.customer_name LIKE CONCAT('%', #{customerName}, '%')
        </if>
        <if test="params.dataScope != null and params.dataScope != ''">
            ${params.dataScope}
        </if>
    </select>

    <select id="selectCrmPaymentPlanById" parameterType="Long" resultMap="CrmPaymentPlanResult">
        <include refid="selectCrmPaymentPlanVo"/>
        where pp.plan_id = #{planId}
    </select>

    <select id="countUnpaidByOrderId" parameterType="Long" resultType="int">
        select count(*) from crm_payment_plan
        where order_id = #{orderId}
          and del_flag = '0' and status != '1'
    </select>

    <insert id="insertCrmPaymentPlan" parameterType="CrmPaymentPlan" useGeneratedKeys="true" keyProperty="planId">
        insert into crm_payment_plan
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="planId != null">plan_id,</if>
            <if test="orderId != null">order_id,</if>
            <if test="contractId != null">contract_id,</if>
            <if test="planAmount != null">plan_amount,</if>
            <if test="actualAmount != null">actual_amount,</if>
            <if test="planDate != null">plan_date,</if>
            <if test="actualDate != null">actual_date,</if>
            <if test="status != null and status != ''">status,</if>
            <if test="paymentMethod != null and paymentMethod != ''">payment_method,</if>
            <if test="belongUserId != null">belong_user_id,</if>
            <if test="belongDeptId != null">belong_dept_id,</if>
            <if test="createBy != null and createBy != ''">create_by,</if>
            <if test="remark != null and remark != ''">remark,</if>
            create_time
        </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="planId != null">#{planId},</if>
            <if test="orderId != null">#{orderId},</if>
            <if test="contractId != null">#{contractId},</if>
            <if test="planAmount != null">#{planAmount},</if>
            <if test="actualAmount != null">#{actualAmount},</if>
            <if test="planDate != null">#{planDate},</if>
            <if test="actualDate != null">#{actualDate},</if>
            <if test="status != null and status != ''">#{status},</if>
            <if test="paymentMethod != null and paymentMethod != ''">#{paymentMethod},</if>
            <if test="belongUserId != null">#{belongUserId},</if>
            <if test="belongDeptId != null">#{belongDeptId},</if>
            <if test="createBy != null and createBy != ''">#{createBy},</if>
            <if test="remark != null and remark != ''">#{remark},</if>
            sysdate()
        </trim>
    </insert>

    <update id="updateCrmPaymentPlan" parameterType="CrmPaymentPlan">
        update crm_payment_plan
        <set>
            <if test="orderId != null">order_id = #{orderId},</if>
            <if test="contractId != null">contract_id = #{contractId},</if>
            <if test="planAmount != null">plan_amount = #{planAmount},</if>
            <if test="actualAmount != null">actual_amount = #{actualAmount},</if>
            <if test="planDate != null">plan_date = #{planDate},</if>
            <if test="actualDate != null">actual_date = #{actualDate},</if>
            <if test="status != null">status = #{status},</if>
            <if test="paymentMethod != null">payment_method = #{paymentMethod},</if>
            <if test="belongUserId != null">belong_user_id = #{belongUserId},</if>
            <if test="belongDeptId != null">belong_dept_id = #{belongDeptId},</if>
            <if test="updateBy != null and updateBy != ''">update_by = #{updateBy},</if>
            <if test="remark != null">remark = #{remark},</if>
            update_time = sysdate()
        </set>
        where plan_id = #{planId}
    </update>

    <update id="deleteCrmPaymentPlanByIds" parameterType="String">
        update crm_payment_plan set del_flag = '2' where plan_id in
        <foreach collection="array" item="planId" open="(" separator="," close=")">
            #{planId}
        </foreach>
    </update>

    <update id="markAsPaid" parameterType="CrmPaymentPlan">
        update crm_payment_plan
        set status = '1',
            actual_amount = #{actualAmount},
            actual_date = #{actualDate},
            payment_method = #{paymentMethod},
            <if test="updateBy != null and updateBy != ''">update_by = #{updateBy},</if>
            update_time = sysdate()
        where plan_id = #{planId}
    </update>

    <update id="updatePaymentPlanBelongByCustomerId">
        update crm_payment_plan pp
        inner join crm_order o on pp.order_id = o.order_id
        set pp.belong_user_id = #{belongUserId}, pp.belong_dept_id = #{belongDeptId}
        where o.customer_id = #{customerId}
    </update>

</mapper>
