<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.crm.mapper.CrmOrderItemMapper">

    <resultMap type="CrmOrderItem" id="CrmOrderItemResult">
        <id     property="itemId"          column="item_id"            />
        <result property="orderId"         column="order_id"           />
        <result property="productId"       column="product_id"         />
        <result property="productName"     column="product_name"       />
        <result property="productPrice"    column="product_price"      />
        <result property="quantity"        column="quantity"           />
        <result property="subtotal"        column="subtotal"           />
        <result property="remark"          column="remark"             />
    </resultMap>

    <sql id="selectCrmOrderItemVo">
        select i.item_id, i.order_id, i.product_id, i.product_name, i.product_price,
               i.quantity, i.subtotal, i.remark
        from crm_order_item i
    </sql>

    <select id="selectCrmOrderItemByOrderId" parameterType="Long" resultMap="CrmOrderItemResult">
        <include refid="selectCrmOrderItemVo"/>
        where i.order_id = #{orderId}
    </select>

    <insert id="insertCrmOrderItem" parameterType="CrmOrderItem" useGeneratedKeys="true" keyProperty="itemId">
        insert into crm_order_item
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="itemId != null">item_id,</if>
            <if test="orderId != null">order_id,</if>
            <if test="productId != null">product_id,</if>
            <if test="productName != null and productName != ''">product_name,</if>
            <if test="productPrice != null">product_price,</if>
            <if test="quantity != null">quantity,</if>
            <if test="subtotal != null">subtotal,</if>
            <if test="remark != null and remark != ''">remark,</if>
        </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="itemId != null">#{itemId},</if>
            <if test="orderId != null">#{orderId},</if>
            <if test="productId != null">#{productId},</if>
            <if test="productName != null and productName != ''">#{productName},</if>
            <if test="productPrice != null">#{productPrice},</if>
            <if test="quantity != null">#{quantity},</if>
            <if test="subtotal != null">#{subtotal},</if>
            <if test="remark != null and remark != ''">#{remark},</if>
        </trim>
    </insert>

    <insert id="insertCrmOrderItems" parameterType="java.util.List">
        insert into crm_order_item (order_id, product_id, product_name, product_price, quantity, subtotal, remark) values
        <foreach collection="list" item="item" separator=",">
            (#{item.orderId}, #{item.productId}, #{item.productName}, #{item.productPrice}, #{item.quantity}, #{item.subtotal}, #{item.remark})
        </foreach>
    </insert>

    <update id="updateCrmOrderItem" parameterType="CrmOrderItem">
        update crm_order_item
        <set>
            <if test="productId != null">product_id = #{productId},</if>
            <if test="productName != null">product_name = #{productName},</if>
            <if test="productPrice != null">product_price = #{productPrice},</if>
            <if test="quantity != null">quantity = #{quantity},</if>
            <if test="subtotal != null">subtotal = #{subtotal},</if>
            <if test="remark != null">remark = #{remark},</if>
        </set>
        where item_id = #{itemId}
    </update>

    <delete id="deleteCrmOrderItemByOrderId" parameterType="Long">
        delete from crm_order_item where order_id = #{orderId}
    </delete>

    <delete id="deleteCrmOrderItemByIds" parameterType="String">
        delete from crm_order_item where item_id in
        <foreach collection="array" item="itemId" open="(" separator="," close=")">
            #{itemId}
        </foreach>
    </delete>

    <select id="countTopProducts" resultType="java.util.Map">
        SELECT p.product_name AS name, SUM(i.quantity) AS value
        FROM crm_order_item i
        JOIN crm_order o ON i.order_id = o.order_id
        JOIN crm_product p ON i.product_id = p.product_id
        WHERE o.del_flag = '0' AND p.del_flag = '0'
        GROUP BY i.product_id, p.product_name
        ORDER BY value DESC
        LIMIT #{limit}
    </select>

    <select id="selectByProductName" resultType="java.util.Map">
        SELECT i.*, o.order_no, p.product_name
        FROM crm_order_item i
        JOIN crm_order o ON i.order_id = o.order_id
        JOIN crm_product p ON i.product_id = p.product_id
        WHERE p.product_name = #{productName}
        LIMIT 50
    </select>

</mapper>
