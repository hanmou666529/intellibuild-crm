<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.crm.ai.copilot.mapper.CopilotSessionMapper">
    <resultMap type="com.ruoyi.crm.ai.copilot.session.CopilotSession" id="CopilotSessionResult">
        <id property="sessionId" column="session_id"/>
        <result property="userId" column="user_id"/>
        <result property="title" column="title"/>
        <result property="context" column="context"/>
        <result property="createTime" column="create_time"/>
        <result property="updateTime" column="update_time"/>
    </resultMap>

    <sql id="selectVo">
        SELECT session_id, user_id, title, context, create_time, update_time
        FROM sys_ai_copilot_session
    </sql>

    <select id="selectBySessionId" resultMap="CopilotSessionResult">
        <include refid="selectVo"/> WHERE session_id = #{sessionId}
    </select>

    <select id="selectByUserId" resultMap="CopilotSessionResult">
        <include refid="selectVo"/> WHERE user_id = #{userId} ORDER BY update_time DESC
    </select>

    <insert id="insert" parameterType="com.ruoyi.crm.ai.copilot.session.CopilotSession">
        INSERT INTO sys_ai_copilot_session (session_id, user_id, title, context, create_time, update_time)
        VALUES (#{sessionId}, #{userId}, #{title}, #{context}, sysdate(), sysdate())
    </insert>

    <update id="updateContext" parameterType="com.ruoyi.crm.ai.copilot.session.CopilotSession">
        UPDATE sys_ai_copilot_session
        SET context = #{context}, update_time = sysdate()
        WHERE session_id = #{sessionId}
    </update>

    <update id="updateTitle" parameterType="com.ruoyi.crm.ai.copilot.session.CopilotSession">
        UPDATE sys_ai_copilot_session
        SET title = #{title}, update_time = sysdate()
        WHERE session_id = #{sessionId}
    </update>

    <delete id="deleteBySessionId">
        DELETE FROM sys_ai_copilot_session WHERE session_id = #{sessionId}
    </delete>

    <delete id="deleteByUserId">
        DELETE FROM sys_ai_copilot_session WHERE user_id = #{userId}
    </delete>
</mapper>
